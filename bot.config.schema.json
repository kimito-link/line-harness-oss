{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "project": { "type": "string" },
    "defaultProject": { "type": "string" },
    "llm": {
      "type": "object",
      "required": ["provider", "model", "maxOutputTokens", "timeoutMs", "dailyCallBudget"],
      "properties": {
        "provider": { "enum": ["groq"] },
        "model": { "type": "string" },
        "apiKeySecretName": { "type": "string" },
        "maxOutputTokens": { "type": "integer", "minimum": 64, "maximum": 4096 },
        "timeoutMs": { "type": "integer", "minimum": 1000 },
        "dailyCallBudget": { "type": "integer", "minimum": 1 },
        "chain": {
          "type": "array",
          "description": "無応答ゼロ化チェーン（2026-07-17追加）。省略可: 未指定ならprovider/model/timeoutMsから1段チェーンを合成する。",
          "items": {
            "type": "object",
            "required": ["provider", "model", "timeoutMs"],
            "properties": {
              "provider": { "enum": ["groq", "gemini", "workers-ai"] },
              "model": { "type": "string" },
              "timeoutMs": { "type": "integer", "minimum": 1000 }
            }
          }
        },
        "vision": {
          "type": "object",
          "description": "画像認識のvisionチェーン（2026-07-17追加）。省略可: 未指定ならdisabled。workers-aiは許可しない（品質・提供状況の理由）。",
          "properties": {
            "enabled": { "type": "boolean" },
            "maxDescriptionTokens": { "type": "integer", "minimum": 32 },
            "chain": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["provider", "model", "timeoutMs"],
                "properties": {
                  "provider": { "enum": ["groq", "gemini"] },
                  "model": { "type": "string" },
                  "timeoutMs": { "type": "integer", "minimum": 1000 }
                }
              }
            }
          }
        },
        "video": {
          "type": "object",
          "description": "動画の説明文生成設定（2026-07-19追加）。省略可: 未指定ならdisabled。Geminiのみ対応（OpenAI互換chat/completionsはvideo_url非対応、ネイティブgenerateContent APIのinline_dataでのみ動作するため）。",
          "properties": {
            "enabled": { "type": "boolean" },
            "model": { "type": "string" },
            "timeoutMs": { "type": "integer", "minimum": 1000 },
            "maxDescriptionTokens": { "type": "integer", "minimum": 32 },
            "maxInputBytes": { "type": "integer", "minimum": 1, "description": "この値を超える動画はdescribeを諦め[動画]ラベルのみ保存する（fail-closed）。" }
          }
        },
        "audio": {
          "type": "object",
          "description": "音声の説明文生成設定（2026-07-19追加）。省略可: 未指定ならdisabled。Geminiのみ対応（OpenAI互換chat/completionsのinput_audio content typeを使用）。",
          "properties": {
            "enabled": { "type": "boolean" },
            "model": { "type": "string" },
            "timeoutMs": { "type": "integer", "minimum": 1000 },
            "maxDescriptionTokens": { "type": "integer", "minimum": 32 },
            "maxInputBytes": { "type": "integer", "minimum": 1, "description": "この値を超える音声はdescribeを諦め[音声]ラベルのみ保存する（fail-closed）。" }
          }
        }
      }
    },
    "line": {
      "type": "object",
      "properties": {
        "channelSecretName": { "type": "string" },
        "channelAccessTokenSecretName": { "type": "string" }
      }
    },
    "knowledgePack": { "type": "string" },
    "escalation": {
      "type": "object",
      "properties": {
        "mode": { "type": "string" }
      }
    },
    "cache": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "ttlHours": { "type": "integer", "minimum": 1 }
      }
    },
    "retrieval": {
      "type": "object",
      "properties": {
        "topK": { "type": "integer", "minimum": 1 },
        "minScore": { "type": "number" }
      }
    },
    "projects": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["knowledgePack"],
        "properties": {
          "knowledgePack": { "type": "string" }
        }
      }
    },
    "urlContext": {
      "type": "object",
      "description": "ユーザーがLINEで共有したURLの本文を安全fetch+抽出してsystem promptに注入する機能（2026-07-17追加）。省略可: 未指定ならdisabled。",
      "properties": {
        "enabled": { "type": "boolean" },
        "timeoutMs": { "type": "integer", "minimum": 1000 },
        "maxContentBytes": { "type": "integer", "minimum": 1024 },
        "maxExtractChars": { "type": "integer", "minimum": 100 }
      }
    }
  },
  "oneOf": [
    { "required": ["project", "llm", "knowledgePack"] },
    { "required": ["defaultProject", "llm", "projects"] }
  ]
}
